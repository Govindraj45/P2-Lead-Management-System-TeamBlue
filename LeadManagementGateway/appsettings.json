{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "GatewayHealth": {
    "MongoConnectionString": "mongodb://localhost:27017",
    "MongoDatabaseName": "LeadManagementSystem_Dev",
    "BackendHealthPath": "api/health",
    "SlowResponseThresholdMs": 10,
    "RequestTimeoutMs": 3000
  },
  "Consul": {
    "Address": "http://localhost:8500",
    "ServiceNames": [
      "lead-management-service"
    ]
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "leads-route": {
        "ClusterId": "lead-management-cluster",
        "Match": {
          "Path": "/gateway/leads/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway/leads" },
          { "PathPrefix": "/api/leads" }
        ]
      },
      "reps-route": {
        "ClusterId": "lead-management-cluster",
        "Match": {
          "Path": "/gateway/reps/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway/reps" },
          { "PathPrefix": "/api/reps" }
        ]
      },
      "interactions-route": {
        "ClusterId": "lead-management-cluster",
        "Match": {
          "Path": "/gateway/interactions/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway/interactions" },
          { "PathPrefix": "/api/interactions" }
        ]
      },
      "reports-route": {
        "ClusterId": "lead-management-cluster",
        "Match": {
          "Path": "/gateway/reports/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway/reports" },
          { "PathPrefix": "/api/reports" }
        ]
      },
      "downstream-health-route": {
        "ClusterId": "lead-management-cluster",
        "Match": {
          "Path": "/gateway/downstream-health"
        },
        "Transforms": [
          { "PathSet": "/api/health" }
        ]
      }
    },
    "Clusters": {
      "lead-management-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001/"
          }
        }
      }
    }
  }
}
