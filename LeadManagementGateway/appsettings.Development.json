{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "GatewayHealth": {
    "MongoConnectionString": "mongodb://localhost:27017",
    "MongoDatabaseName": "LeadManagementSystem_Dev",
    "BackendHealthPath": "api/health",
    "SlowResponseThresholdMs": 10,
    "RequestTimeoutMs": 3000
  },
  "Consul": {
    "Address": "http://localhost:8500",
    "ServiceNames": [
      "lead-management-service"
    ]
  },
  "ReverseProxy": {
    "Clusters": {
      "lead-management-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001/"
          }
        }
      }
    }
  }
}
