{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "LeadManagementSystem",
    "LeadsCollectionName": "Leads",
    "SalesRepsCollectionName": "SalesRepresentatives",
    "InteractionsCollectionName": "Interactions",
    "CountersCollectionName": "Counters"
  },
  "Consul": {
    "Address": "http://localhost:8500",
    "ServiceName": "lead-management-service",
    "ServiceId": "lead-management-service-5001",
    "ServiceAddress": "localhost",
    "ServicePort": 5001,
    "HealthCheckEndpoint": "/api/health",
    "HealthCheckIntervalSeconds": 10,
    "HealthCheckTimeoutSeconds": 5,
    "DeregisterCriticalAfterMinutes": 1
  }
}
