## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
bin/
obj/
out/

# User-specific files
*.user
*.userosscache
*.suo
*.userprefs

# Rider / VS Code
.idea/
.vscode/

# VS Code settings (optional: keep if you want shared config)
# .vscode/settings.json

# Logs
*.log

# ASP.NET Core logs
logs/

# OS files
.DS_Store
Thumbs.db

# Environment variables
.env
.env.*

# Secrets
appsettings.Development.json
appsettings.*.json

# Publish output
publish/

# Node modules (if frontend exists inside project)
node_modules/

# Coverage / Test results
coverage/
TestResults/

# NuGet
*.nupkg
.nuget/
packages/

# EF Core migrations snapshot backups (optional)
*Migrations/*.Designer.cs
*Migrations/*.resx

# SQL Server local DB files
*.mdf
*.ldf

# Docker
docker-compose.override.yml

# Azure / deployment
*.publishsettings

# Resharper
_ReSharper*/
*.DotSettings.user

# Backup & temp files
*.bak
*.tmp
*.temp

# JetBrains Rider
*.sln.iml